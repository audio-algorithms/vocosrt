# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Project artifacts (large binaries, training intermediates, logs)
datasets/
checkpoints/*.pt
checkpoints/*.bin
checkpoints/*.safetensors
checkpoints/*.ckpt
checkpoints/*.onnx
!checkpoints/.gitkeep
!checkpoints/manifest.json

# Reports and demo outputs (regenerated by run_full_validation.py)
reports/test_results/
reports/parity_report.html
reports/*.png
reports/*.json
demos/assets/*
!demos/assets/.gitkeep
!reports/.gitkeep

# Tests' downloaded data
tests/data/*
!tests/data/.gitkeep

# Setup completion marker
.setup_complete

# Logs
*.log

# Docs generated
docs/generated/test_run_*/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Notebooks
.ipynb_checkpoints/
